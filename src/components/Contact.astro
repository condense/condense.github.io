---
import Icon from './Icon.astro';
---
<section class="section" id="contact">
  <div class="wrap">
    <div class="contact-panel">
      <h2>Tell us about your data problem.</h2>
      <p>We'll come back to you within a working day with honest thoughts — even if we aren't the right team for the job.</p>
      <div class="actions">
        <a class="btn btn-primary" href="mailto:hello@condense.com.au">
          Email us
          <span class="arr"><Icon name="arrow" size={16} /></span>
        </a>
        <a class="btn btn-ghost" href="tel:+61428740978">Call 0428 740 978</a>
      </div>
      <div class="info">
        <span><a href="mailto:hello@condense.com.au">hello@condense.com.au</a></span>
        <span>Level 3, 13–17 Castray Esplanade, Battery Point TAS 7004</span>
        <span>Mon–Fri · 9am–5pm AEST</span>
      </div>
    </div>
  </div>
</section>
