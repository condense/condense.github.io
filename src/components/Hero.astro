---
import Icon from './Icon.astro';
---
<section class="hero" id="top">
  <div class="wrap">
    <h1>
      Software that turns data into <span class="accent">better decisions</span>.
    </h1>
    <p class="lede">
      We're a small, senior studio in Hobart. For ten years we've built dashboards, web platforms and mobile apps with public-sector and research clients — quietly, carefully, well.
    </p>
    <div class="actions">
      <a class="btn btn-primary" href="/#contact">
        Start a project
        <span class="arr"><Icon name="arrow" size={16} /></span>
      </a>
      <a class="btn btn-ghost" href="/#work">See the work</a>
    </div>
    <div class="meta">
      <div class="item"><span class="dot"></span> Hobart, Tasmania</div>
      <div class="item">Est. 2014 · Independent</div>
    </div>
  </div>
</section>
