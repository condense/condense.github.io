---
import { home } from '../copy/home.ts';
const { label, lines } = home.trusted;
---
<section class="trusted">
  <div class="wrap">
    <div class="inner">
      <span class="label">{label}</span>
      <div class="lines">
        {lines.map((c) => <span>{c}</span>)}
      </div>
    </div>
  </div>
</section>
