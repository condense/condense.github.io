---
// Copy lives in src/copy/home.ts. Lede paragraphs may carry inline markup (e.g. <b>),
// so they render via set:html.
import { home } from '../copy/home.ts';
import { site } from '../copy/site.ts';
const { eyebrow, title, lede, team } = home.about;
const { linkedin } = site.contact;
---
<section class="section" id="practice">
  <div class="wrap">
    <div class="section-header">
      <span class="section-eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
    </div>
    <div class="about-grid">
      <div class="about-lede">
        {lede.map((para) => <p set:html={para} />)}
        <!-- <a class="about-company-link" href={linkedin} target="_blank" rel="noopener noreferrer">Follow Condense on LinkedIn</a> -->
      </div>
      <div class="team">
        {team.map((m) => (
          <div class="member">
            <a class="member-card-link" href={m.linkedin} aria-label={`${m.name} on LinkedIn`} target="_blank" rel="noopener noreferrer"></a>
            <img src={m.photo} alt={m.name} width="80" height="80" />
            <div>
              <h4>{m.name}</h4>
              <div class="role">{m.role}</div>
              <p>{m.bio}</p>
              <div class="socials">
                <a href={`mailto:${m.email}`}>Email</a>
                <a href={m.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
