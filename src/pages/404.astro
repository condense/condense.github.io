---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Page not found — Condense">
  <Nav />
  <main>
    <section class="section" id="top">
      <div class="wrap">
        <div class="section-header">
          <span class="section-eyebrow">404</span>
          <h2 class="section-title">We couldn't find that page.</h2>
          <p class="section-lede">The link may be old or mistyped. Head back to the home page, or get in touch and we'll point you the right way.</p>
        </div>
        <div class="actions" style="display:flex; gap:12px; flex-wrap:wrap;">
          <a class="btn btn-primary" href="/">Back to home</a>
          <a class="btn btn-ghost" href="mailto:hello@condense.com.au">Email us</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
