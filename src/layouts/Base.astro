---
import '../styles/site.css';

interface Props {
  title?: string;
  description?: string;
  /** Absolute canonical URL; legacy pages pass the homepage to consolidate ranking. */
  canonical?: string;
}

const {
  title = 'Condense — Software that turns data into better decisions',
  description = 'Condense is an independent software studio in Hobart, Tasmania. We help organisations turn data into informed action.',
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/assets/og-head-5.jpg', Astro.site).href;
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href="/assets/c-element.svg" type="image/svg+xml" />

    <!-- Inter, loaded non-blocking with swap (replaces the prototype's @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
    />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:site_name" content="Condense" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#top">Skip to content</a>
    <slot />
  </body>
</html>
